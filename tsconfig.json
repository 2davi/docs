{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "types": ["node"],
    "allowJs": true,
    "skipLibCheck": true
  },
  "include": [
    "docs/**/*.ts",
    "docs/**/*.mts",
    "docs/**/*.d.ts",
    "docs/**/*.vue"
  ]
}